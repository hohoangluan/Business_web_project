# --- Django core ---
SECRET_KEY=thay-bang-chuoi-random
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# --- Database (để trống = SQLite local; Render tự set DATABASE_URL) ---
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- Gmail SMTP ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=you@gmail.com
EMAIL_HOST_PASSWORD=app-password-cua-ban

# --- Cloudinary (media). Để False khi dev local. ---
USE_CLOUDINARY=False
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Face recognition API ---
FACE_API_BASE_URL=https://kluan-facial-recognition-for-attendance-tracking.hf.space
